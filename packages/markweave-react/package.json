{
  "name": "@markweave/react",
  "version": "0.1.2",
  "type": "module",
  "description": "React adapter for the Markweave Markdown-first WYSIWYG editor.",
  "license": "MIT",
  "keywords": [
    "markdown",
    "wysiwyg",
    "editor",
    "tiptap",
    "prosemirror",
    "react",
    "markweave"
  ],
  "homepage": "https://github.com/Refinex-Space/markweave#readme",
  "bugs": {
    "url": "https://github.com/Refinex-Space/markweave/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Refinex-Space/markweave.git",
    "directory": "packages/markweave-react"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "style": "./styles.css",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist",
    "styles.css",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "lucide-react": "^0.547.0",
    "markweave": "workspace:^"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
