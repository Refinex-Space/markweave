{
  "name": "markweave",
  "version": "0.1.8",
  "type": "module",
  "description": "Markdown-first WYSIWYG editor built on Tiptap and CodeMirror, providing Typora-like editing experience with block-level structure, slash commands, and rich text tooling.",
  "license": "MIT",
  "keywords": [
    "markdown",
    "wysiwyg",
    "editor",
    "tiptap",
    "prosemirror",
    "mermaid",
    "math",
    "react",
    "vue"
  ],
  "homepage": "https://github.com/Refinex-Space/markweave#readme",
  "bugs": {
    "url": "https://github.com/Refinex-Space/markweave/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Refinex-Space/markweave.git",
    "directory": "packages/markweave"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "style": "./dist/styles.css",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "typesVersions": {
    "*": {
      "react": [
        "./react.d.ts"
      ],
      "vue2": [
        "./vue2.d.ts"
      ],
      "vue3": [
        "./vue3.d.ts"
      ],
      "styles.css": [
        "./dist/styles.css"
      ],
      "internal/*": [
        "./dist/types/*"
      ],
      "*": [
        "./dist/types/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./react.d.ts",
      "import": "./react.js"
    },
    "./vue3": {
      "types": "./vue3.d.ts",
      "import": "./vue3.js"
    },
    "./vue2": {
      "types": "./vue2.d.ts",
      "import": "./vue2.js"
    },
    "./internal/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/*.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "react.js",
    "react.d.ts",
    "vue2.js",
    "vue2.d.ts",
    "vue3.js",
    "vue3.d.ts",
    "styles.css",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json && node -e \"require('node:fs').copyFileSync('src/editor-core/markweave-editor.css','dist/styles.css')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-code-block-lowlight": "^3.27.1",
    "@tiptap/extension-emoji": "^3.27.1",
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-horizontal-rule": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-mathematics": "^3.27.1",
    "@tiptap/extension-heading": "^3.27.1",
    "@tiptap/extension-paragraph": "^3.27.1",
    "@tiptap/extension-subscript": "^3.27.1",
    "@tiptap/extension-superscript": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/extension-task-item": "^3.27.1",
    "@tiptap/extension-task-list": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/markdown": "3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "lowlight": "^3.3.0",
    "mermaid": "^11.16.0",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.3"
  },
  "devDependencies": {
    "@tiptap/react": "^3.27.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "lucide-react": "^0.547.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
