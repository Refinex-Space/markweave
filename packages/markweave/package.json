{
  "name": "markweave",
  "version": "0.1.0",
  "type": "module",
  "description": "Markdown-first WYSIWYG editor built on Tiptap and CodeMirror, providing Typora-like editing experience with block-level structure, slash commands, and rich text tooling.",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "style": "./dist/styles.css",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "typesVersions": {
    "*": {
      "react": [
        "./dist/types/react/index.d.ts"
      ],
      "vue2": [
        "./dist/types/vue2/index.d.ts"
      ],
      "vue3": [
        "./dist/types/vue3/index.d.ts"
      ],
      "styles.css": [
        "./dist/styles.css"
      ],
      "*": [
        "./dist/types/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/types/react/index.d.ts",
      "import": "./dist/react.js"
    },
    "./vue3": {
      "types": "./dist/types/vue3/index.d.ts",
      "import": "./dist/vue3.js"
    },
    "./vue2": {
      "types": "./dist/types/vue2/index.d.ts",
      "import": "./dist/vue2.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "react.js",
    "vue2.js",
    "vue3.js",
    "styles.css",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && vite build && tsc -p tsconfig.build.json && node -e \"require('node:fs').copyFileSync('src/editor-core/markweave-editor.css','dist/styles.css')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@tiptap/react": "^3.27.1",
    "@tiptap/vue-2": "3.27.1",
    "@tiptap/vue-3": "^3.27.1",
    "lucide-react": "^0.547.0",
    "lucide-vue-next": "^0.547.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vue": "^2.6.12 || ^3.5.0"
  },
  "peerDependenciesMeta": {
    "@tiptap/react": {
      "optional": true
    },
    "@tiptap/vue-3": {
      "optional": true
    },
    "@tiptap/vue-2": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "lucide-vue-next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-code-block-lowlight": "^3.27.1",
    "@tiptap/extension-emoji": "^3.27.1",
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-horizontal-rule": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-mathematics": "^3.27.1",
    "@tiptap/extension-subscript": "^3.27.1",
    "@tiptap/extension-superscript": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/extension-task-item": "^3.27.1",
    "@tiptap/extension-task-list": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/markdown": "3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "lowlight": "^3.3.0",
    "mermaid": "^11.16.0",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.3"
  },
  "devDependencies": {
    "@tiptap/react": "^3.27.1",
    "@tiptap/vue-2": "3.27.1",
    "@tiptap/vue-3": "^3.27.1",
    "lucide-react": "^0.547.0",
    "lucide-vue-next": "^0.547.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vue": "^3.5.25"
  }
}
